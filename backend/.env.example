# ============================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# BASE DE DATOS MYSQL (XAMPP por defecto)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jn31_importaciones

# ============================================================
# SEGURIDAD - JWT (JSON Web Token)
# Cambiar este valor en producción por una cadena aleatoria larga
# ============================================================
JWT_SECRET=jn31_importaciones_secret_key_change_in_production_2026
JWT_EXPIRATION=8h

# ============================================================
# CORS - dominios permitidos (frontend)
# ============================================================
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ============================================================
# SUBIDA DE ARCHIVOS
# ============================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
